{
  "expo": {
    "name": "Mis Finanzas",
    "slug": "finanzas-app",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "finanzas",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tufinanzas.app",
      "infoPlist": {
        "UIStatusBarHidden": false,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tufinanzas.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "scope": "/",
      "name": "Mis Finanzas",
      "shortName": "Finanzas",
      "description": "App de finanzas personales - Controla tus ingresos, gastos, metas y más",
      "lang": "es-ES",
      "startUrl": "/",
      "display": "standalone",
      "orientation": "portrait-primary",
      "backgroundColor": "#0f0f1a",
      "themeColor": "#0f0f1a",
      "preferRelatedApplications": false,
      "barStyle": "black-translucent",
      "capabilities": ["push", "offline"],
      "splash": {
        "backgroundColor": "#0f0f1a",
        "resizeMode": "contain"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f1b045a3-3d8f-41bc-86a7-3cf019868e93"
      }
    }
  }
}
