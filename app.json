{
  "expo": {
    "name": "Mis Finanzas",
    "slug": "finanzas-app",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "finanzas",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tufinanzas.app",
      "infoPlist": {
        "UIStatusBarHidden": false
      }
    },
    "android": {
      "package": "com.tufinanzas.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
